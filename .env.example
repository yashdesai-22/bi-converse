# Get a token at https://huggingface.co/settings/tokens (read scope is enough)
HF_TOKEN=hf_your_token_here

# Optional: override default model (must be served by HF Inference Providers)
# HF_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Optional: provider routing ("auto" picks an available provider)
# HF_PROVIDER=auto
